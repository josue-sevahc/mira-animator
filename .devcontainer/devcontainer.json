// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/universal
{
	"name": "Default Linux Universal",
	"image": "mcr.microsoft.com/devcontainers/universal:6-linux",

	// Capabilities de rede exigidas pelo firewall (iptables/ipset).
	"runArgs": [
		"--cap-add=NET_ADMIN",
		"--cap-add=NET_RAW"
	],

	// Monta a pasta de chaves do host (C:\KEYS) dentro do container como /keys.
	// readonly = o container pode LER, mas nao alterar nem apagar as chaves.
	// Bind mount eh "ao vivo": editar C:\KEYS\.env no Windows reflete na hora.
	"mounts": [
		"source=C:\\KEYS,target=/keys,type=bind,readonly"
	],

	// Roda UMA vez, quando o container e criado:
	// 1. instala o Claude Code e as ferramentas do firewall;
	// 2. corrige quebras de linha do firewall (caso o Windows tenha salvo em CRLF);
	// 3. define a identidade do git para os commits;
	// 4. carrega /keys/.env em todo terminal novo (inclui GH_TOKEN, ao vivo);
	// 5. configura o gh como credential helper do git (le GH_TOKEN do ambiente).
	"postCreateCommand": "npm install -g @anthropic-ai/claude-code && sudo apt-get update && sudo apt-get install -y iptables ipset dnsutils jq && sudo sed -i 's/\\r$//' .devcontainer/init-firewall.sh && sudo chmod +x .devcontainer/init-firewall.sh && git config --global user.name 'sandeco' && git config --global user.email 'physialtda@gmail.com' && (grep -q '/keys/.env' ~/.bashrc || echo 'set -a; [ -f /keys/.env ] && . /keys/.env; set +a' >> ~/.bashrc) && (set -a; [ -f /keys/.env ] && . /keys/.env; set +a; gh auth setup-git 2>/dev/null || true)",

	// Roda TODA vez que o container inicia: aplica o firewall.
	// (As regras de iptables nao persistem entre reinicios, por isso aqui.)
	"postStartCommand": "sudo .devcontainer/init-firewall.sh"

	// Conectar como root (nao recomendado): descomente abaixo.
	// "remoteUser": "root"
}
